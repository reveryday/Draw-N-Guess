/* 页面容器 */
.container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* card setting */
.card {
  margin: 0;
  max-width: 680rpx;
  padding: 44rpx 34rpx 34rpx;
}

.card-hero {
  margin-bottom: 20rpx;
}

.card-eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4f0ff;
  color: #6b59c9;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

.card-title {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 12rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0ebff;
}

.card-title text:first-child {
  font-size: 42rpx;
  font-weight: 700;
  color: #43356f;
  line-height: 1.15;
}

.card-subtitle {
  display: block;
  font-size: 25rpx;
  color: #8e88a7;
  font-weight: normal;
  line-height: 1.5;
}

/* 设置项 */
.setting-item {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
  margin-bottom: 0;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f3efff;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #43356f;
  font-weight: 600;
}

.setting-value {
  font-size: 26rpx;
  color: #7566d9;
  font-weight: 700;
}

.setting-input {
  flex: 1;
  max-width: 60%;
  min-width: 30%;
  padding: 15rpx 20rpx;
  border: 2rpx solid #e0d7ff;
  border-radius: 18rpx;
  font-size: 28rpx;
  background: #f8f6ff;
  color: #3b315a;
  text-align: right;
}
.setting-input:focus {
  border-color: #7566d9;
  background: white;
}

/* 数字选择器 */
.number-selector {
  display: flex;
  align-items: center;
  gap: 18rpx;
  justify-content: flex-end;
}

.number-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
  border: none;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.number-btn:disabled {
  background: #d8d2ef;
}

.number-btn:active:not(:disabled) {
  background: #5a4bc0;
}

.number-value {
  min-width: 96rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #43356f;
  text-align: center;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: #f8f6ff;
}

/* 时间选择器 */
.time-selector {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.time-option {
  min-height: 96rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e0d7ff;
  border-radius: 22rpx;
  font-size: 26rpx;
  color: #6d6297;
  background: #f8f6ff;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.time-option.active {
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
  border-color: #7566d9;
  box-shadow: 0 12rpx 24rpx rgba(90, 75, 192, 0.18);
}

.time-option:active {
  transform: scale(0.95);
}

/* 题目类型 */
.topic-types {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.topic-type {
  padding: 20rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  background: #fafafa;
  transition: all 0.3s ease;
}

.topic-type.active {
  background: #667eea !important;
  color: white !important;
  border-color: #667eea !important;
}

.topic-type:active {
  transform: scale(0.95);
}

/* 自定义题目 */
.custom-topics {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 25rpx;
  margin-top: 25rpx;
}

.custom-input-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.custom-topic-input {
  flex: 1;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.custom-topic-input:focus {
  border-color: #667eea;
  background: white;
}

.add-topic-btn {
  padding: 15rpx 25rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-topic-btn:disabled {
  background: #ccc;
}

.add-topic-btn:active:not(:disabled) {
  background: #5a6fd8;
}

.custom-topics-list {
  margin-top: 20rpx;
}

.custom-topic-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  background: #e8f2ff;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.topic-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.remove-topic-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
}

.remove-topic-btn:active {
  background: #ff3742;
  transform: scale(0.9);
}

.custom-topics-hint {
  padding: 20rpx;
  background: #fff3cd;
  border: 1rpx solid #ffeaa7;
  border-radius: 10rpx;
  margin-top: 15rpx;
}

.custom-topics-hint text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.4;
}

.list-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.topic-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 15rpx;
  background: #e8f2ff;
  color: #667eea;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.remove-topic {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 密码设置 */
.password-section {
  margin-top: 10rpx;
}

.password-toggle {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.toggle-label {
  font-size: 28rpx;
  color: #333;
}

.password-input {
  margin-top: 15rpx;
}

/* 创建按钮区域 */
.create-section {
  margin-top: 30rpx;
  padding: 6rpx 0 0;
}

.create-btn {
  width: 100%;
  padding: 28rpx 40rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 0;
  color: white;
  border-radius: 999rpx;
}

.create-tips {
  text-align: left;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

.create-tips text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.create-tips text:last-child {
  margin-bottom: 0;
}

/* 加载覆盖层 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

/* 响应式适配 */
@media (max-width: 400px) {
  .container {
    padding: 3%;
  }
  
  .setting-item {
    gap: 15rpx;
  }
  
  .setting-input {
    max-width: 100%;
    text-align: left;
  }
  
  .number-selector,
  .time-selector {
    align-self: stretch;
    justify-content: flex-start;
  }
  
  .time-selector {
    grid-template-columns: 1fr;
  }
}
