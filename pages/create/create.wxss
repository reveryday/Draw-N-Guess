/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

/* 主要按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 15rpx;
  color: white;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* card setting */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 15rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-top: 5rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 25rpx;
  padding: 15rpx 0;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.setting-input {
  flex: 1;
  max-width: 60%;
  min-width: 30%;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  background: #fafafa;
  text-align: right;
}
.setting-input:focus {
  border-color: #667eea;
  background: white;
}

/* 数字选择器 */
.number-selector {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.number-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #667eea;
  color: white;
  border: none;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.number-btn:disabled {
  background: #ccc;
}

.number-btn:active:not(:disabled) {
  background: #5a6fd8;
}

.number-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}

/* 时间选择器 */
.time-selector {
  display: flex;
  gap: 15rpx;
}

.time-option {
  padding: 15rpx 25rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  transition: all 0.3s ease;
}

.time-option.active {
  background: #667eea;
  color: white;
  border-color: #667eea;
}

.time-option:active {
  transform: scale(0.95);
}

/* 题目类型 */
.topic-types {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.topic-type {
  padding: 20rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  background: #fafafa;
  transition: all 0.3s ease;
}

.topic-type.active {
  background: #667eea !important;
  color: white !important;
  border-color: #667eea !important;
}

.topic-type:active {
  transform: scale(0.95);
}

/* 自定义题目 */
.custom-topics {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 25rpx;
  margin-top: 25rpx;
}

.custom-input-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.custom-topic-input {
  flex: 1;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.custom-topic-input:focus {
  border-color: #667eea;
  background: white;
}

.add-topic-btn {
  padding: 15rpx 25rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-topic-btn:disabled {
  background: #ccc;
}

.add-topic-btn:active:not(:disabled) {
  background: #5a6fd8;
}

.custom-topics-list {
  margin-top: 20rpx;
}

.custom-topic-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  background: #e8f2ff;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.topic-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.remove-topic-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
}

.remove-topic-btn:active {
  background: #ff3742;
  transform: scale(0.9);
}

.custom-topics-hint {
  padding: 20rpx;
  background: #fff3cd;
  border: 1rpx solid #ffeaa7;
  border-radius: 10rpx;
  margin-top: 15rpx;
}

.custom-topics-hint text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.4;
}

.list-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.topic-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 15rpx;
  background: #e8f2ff;
  color: #667eea;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.remove-topic {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 密码设置 */
.password-section {
  margin-top: 10rpx;
}

.password-toggle {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.toggle-label {
  font-size: 28rpx;
  color: #333;
}

.password-input {
  margin-top: 15rpx;
}

/* 创建按钮区域 */
.create-section {
  margin-top: 40rpx;
  padding: 0 15rpx;
}

.create-btn {
  width: 100%;
  padding: 30rpx 40rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: white;
  border-radius: 20rpx;
}

.create-btn:disabled {
  background: #ccc !important;
}

.create-tips {
  text-align: left;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

.create-tips text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.create-tips text:last-child {
  margin-bottom: 0;
}

/* 加载覆盖层 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

/* 响应式适配 */
@media (max-width: 400px) {
  .container {
    padding: 3%;
  }
  
  .setting-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 15rpx;
  }
  
  .setting-input {
    max-width: 100%;
    text-align: left;
  }
  
  .number-selector,
  .time-selector {
    align-self: flex-end;
  }
  
  .topic-types {
    gap: 10rpx;
  }
  
  .topic-type {
    padding: 15rpx 20rpx;
    font-size: 26rpx;
  }
}