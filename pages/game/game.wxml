<view class="game-container">

  <!-- 顶部信息栏 -->
  <view class="game-header">
    <view class="game-info">
      <text class="room-id">房间: {{roomCode}}</text>
      <text class="timer" wx:if="{{timeLeft > 0}}">{{timeLeft}}s</text>
    </view>
    <view class="game-status">
      <text class="round-info" wx:if="{{currentRound > 0}}">第{{currentRound}}/{{totalRounds}}轮</text>
    </view>
  </view>

  <!-- 画布区 -->
  <view class="canvas-section">
    <!-- 等待阶段占位 -->
    <view class="canvas-placeholder" wx:if="{{gameStatus !== 'playing'}}">
      <text class="placeholder-text">等待游戏开始...</text>
      <view class="canvas-placeholder-action">
        <button
          wx:if="{{!isOwner}}"
          class="action-btn {{currentUserReady ? 'btn-ready-done' : 'btn-ready'}}"
          bindtap="handleReady"
          disabled="{{currentUserReady}}"
        >{{currentUserReady ? '已准备，等待开始' : '点击准备'}}</button>
        <button
          wx:else
          class="action-btn {{canStartGame ? 'btn-start' : 'btn-start-disabled'}}"
          bindtap="startGame"
          disabled="{{!canStartGame}}"
        >{{canStartGame ? '开始游戏' : (players.length <= 1 ? '等待玩家加入...' : '等待玩家准备...')}}</button>
      </view>
    </view>

    <!-- 出题阶段占位 -->
    <view class="canvas-placeholder" wx:elif="{{roundStatus === 'choosing'}}">
      <text class="placeholder-text" wx:if="{{isDrawer}}">请在下方输入本轮词条</text>
      <text class="placeholder-text" wx:else>等待 {{currentDrawerNickName}} 出题...</text>
      <view class="canvas-placeholder-note">
        <text wx:if="{{isDrawer}}">输入完成后会立即进入作画阶段</text>
        <text wx:else>出题完成后将开始本轮作画</text>
      </view>
    </view>

    <!-- 画画阶段：工具栏 -->
    <block wx:else>
      <view class="canvas-meta">
        <block wx:if="{{isDrawer}}">
          <view class="canvas-header canvas-header-drawer">
            <view class="drawer-word-hint">
              <text class="drawer-word-label">你的词：</text>
              <text class="drawer-word-value">{{drawerWord || '待出题'}}</text>
            </view>
            <view class="canvas-tools">
              <button class="tool-btn {{selectedTool === 'pen' ? 'active' : ''}}" bindtap="selectTool" data-tool="pen">笔</button>
              <button class="tool-btn {{selectedTool === 'eraser' ? 'active' : ''}}" bindtap="selectTool" data-tool="eraser">擦</button>
              <button class="clear-btn" bindtap="clearCanvas">清空</button>
            </view>
          </view>
        </block>
        <view class="guesser-hint" wx:else>
          <text>等待 {{currentDrawerNickName}} 作画，观察画面后输入你的猜测</text>
        </view>
      </view>
      <view class="canvas-stage">
        <canvas
          class="drawing-canvas"
          canvas-id="drawingCanvas"
          width="{{canvasWidth}}"
          height="{{canvasHeight}}"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
          disable-scroll="{{true}}"
          style="pointer-events:{{isDrawer && roundStatus === 'drawing' ? 'auto' : 'none'}}"
        ></canvas>
      </view>
    </block>
  </view>

  <!-- 玩家头像区 -->
  <view class="players-section">
    <scroll-view class="players-list" scroll-x="true">
      <view
        class="player-item {{gameStatus === 'playing' && item.openid === currentDrawer ? 'is-drawer' : ''}}"
        wx:for="{{players}}"
        wx:key="openid"
      >
        <view class="avatar-wrap">
          <image class="player-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}"></image>
          <!-- 等待阶段标记 -->
          <view class="avatar-badge" wx:if="{{gameStatus === 'waiting'}}">
            <text wx:if="{{item.openid === ownerOpenid}}">主</text>
            <text class="badge-check" wx:elif="{{item.isReady}}">✓</text>
          </view>
          <!-- 游戏中标记 -->
          <view class="avatar-badge" wx:elif="{{gameStatus === 'playing'}}">
            <text wx:if="{{item.openid === currentDrawer}}">画</text>
            <text class="badge-check" wx:elif="{{item.hasGuessed}}">对</text>
          </view>
        </view>
        <text class="player-name">{{item.nickName}}</text>
        <text class="player-score" wx:if="{{gameStatus === 'playing'}}">{{item.score || 0}}分</text>
      </view>
    </scroll-view>
  </view>

  <!-- 画手出词弹窗 -->
  <view class="word-modal-mask" wx:if="{{gameStatus === 'playing' && roundStatus === 'choosing' && isDrawer}}">
    <view class="word-modal">
      <text class="word-modal-title">请输入本轮词条</text>
      <text class="word-modal-tip">只有你自己能看到这个词</text>
      <view class="word-modal-row">
        <input
          class="word-modal-input"
          placeholder="例如：苹果"
          bindinput="onWordInput"
          bindconfirm="submitWord"
          value="{{wordInput}}"
          maxlength="10"
          focus="{{true}}"
        />
        <button
          class="word-modal-btn"
          bindtap="submitWord"
          disabled="{{!canSubmitWord}}"
        >确认</button>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <view class="chat-section" wx:if="{{!showGameOver}}">
    <scroll-view class="chat-messages" scroll-y="true">
      <block wx:if="{{gameStatus === 'playing' && roundStatus === 'drawing'}}">
        <view class="message-item {{message.type}}" wx:for="{{messages}}" wx:for-item="message" wx:key="index">
          <view class="message-content" wx:if="{{message.type === 'chat'}}">
            <text class="message-sender">{{message.sender}}: </text>
            <text class="message-text">{{message.content}}</text>
          </view>
          <view class="message-content" wx:elif="{{message.type === 'correct'}}">
            <text class="correct-message">{{message.sender}} 猜对了！</text>
          </view>
        </view>
      </block>
      <view class="chat-empty-state" wx:else>
        <text class="chat-empty-title" wx:if="{{gameStatus === 'waiting'}}">聊天区已就位</text>
        <text class="chat-empty-title" wx:elif="{{roundStatus === 'choosing'}}">等待本轮开始</text>
        <text class="chat-empty-desc" wx:if="{{gameStatus === 'waiting'}}">玩家准备完成后，这里会显示实时猜词消息</text>
        <text class="chat-empty-desc" wx:elif="{{roundStatus === 'choosing'}}">出题完成后，聊天区会切换为实时猜词</text>
        <text class="chat-empty-desc" wx:else>本区域将在作画阶段展示实时消息</text>
      </view>
      <view class="message-item system" wx:if="{{gameStatus === 'playing' && roundStatus === 'drawing' && !messages.length}}">
        <view class="message-content">
          <text class="system-message">猜词消息会显示在这里</text>
        </view>
      </view>
    </scroll-view>
    <view class="chat-input-bar">
      <input
        class="chat-guess-input {{(isDrawer || !(gameStatus === 'playing' && roundStatus === 'drawing')) ? 'is-disabled' : ''}}"
        placeholder="{{gameStatus !== 'playing' ? '游戏开始后开放猜词输入' : (roundStatus === 'choosing' ? '出题完成后开放猜词输入' : (isDrawer ? '画手不可输入猜词' : '输入你的猜测...'))}}"
        bindinput="onChatInput"
        bindconfirm="sendMessage"
        value="{{chatInput}}"
        maxlength="20"
        disabled="{{isDrawer || !(gameStatus === 'playing' && roundStatus === 'drawing')}}"
      />
      <button
        class="chat-send-btn {{(isDrawer || !(gameStatus === 'playing' && roundStatus === 'drawing')) ? 'is-disabled' : ''}}"
        bindtap="sendMessage"
        disabled="{{isDrawer || !canSendMessage || !(gameStatus === 'playing' && roundStatus === 'drawing')}}"
      >发送</button>
    </view>
  </view>

  <!-- 游戏结束弹窗 -->
  <view class="game-over-modal" wx:if="{{showGameOver}}">
    <view class="modal-content">
      <view class="result-hero">
        <text class="result-badge">本局结算</text>
        <text class="modal-title">游戏结束</text>
        <view class="winner-card" wx:if="{{finalScores.length}}">
          <text class="winner-crown">🏆</text>
          <text class="winner-rank">冠军</text>
          <text class="winner-name">{{finalScores[0].nickName}}</text>
          <text class="winner-score">{{finalScores[0].score}}分</text>
        </view>
      </view>
      <view class="final-scores">
        <view class="score-item" wx:for="{{finalScores}}" wx:key="openid">
          <view class="score-left">
            <view class="rank-badge rank-{{index}}">
              <text class="rank">{{index + 1}}</text>
            </view>
            <view class="score-meta">
              <text class="score-name">{{item.nickName}}</text>
              <text class="score-rank-text">第{{index + 1}}名</text>
            </view>
          </view>
          <text class="score-points">{{item.score}}分</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-secondary" bindtap="backToHome">返回首页</button>
        <button class="btn-primary" bindtap="playAgain">再来一局</button>
      </view>
    </view>
  </view>

</view>
