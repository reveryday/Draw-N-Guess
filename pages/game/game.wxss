/* 游戏容器 */
.game-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 游戏头部 */
.game-header {
  background: rgba(255, 255, 255, 0.95);
  padding: 15rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
  flex-shrink: 0;
}

.game-info {
  display: flex;
  gap: 30rpx;
  align-items: center;
}

.room-id {
  font-size: 24rpx;
  color: #666;
}

.current-word {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
  background: #e8f2ff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.timer {
  font-size: 26rpx;
  color: #ff4757;
  font-weight: 600;
}

.game-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 5rpx;
}

.round-info {
  font-size: 24rpx;
  color: #666;
}

.drawer-info {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* 画板区域 */
.canvas-section {
  flex-shrink: 0;
  background: white;
  margin: 10rpx 20rpx 10rpx 20rpx;
  border-radius: 20rpx;
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  height: 45vh;
  overflow: hidden;
}

.canvas-header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.canvas-tools {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.tool-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.tool-btn.active {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

.clear-btn {
  padding: 10rpx 20rpx;
  background: #ff4757;
  color: white;
  border: none;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.drawing-canvas {
  flex: 1;
  width: 100%;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 15rpx;
  min-height: 300rpx;
}

/* 用户头像区域 */
.players-section {
  background: white;
  margin: 0 20rpx 10rpx 20rpx;
  border-radius: 20rpx;
  padding: 15rpx 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.players-list {
  white-space: nowrap;
  display: flex;
}

.player-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
  padding: 15rpx;
  border-radius: 15rpx;
  min-width: 120rpx;
  position: relative;
}

.player-item:last-child {
  margin-right: 0;
}

.player-item.is-drawer {
  background: #e8f2ff;
  border: 2rpx solid #667eea;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-bottom: 10rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.player-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.player-score {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

.player-status {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  display: flex;
  align-items: center;
}

.status-icon {
  font-size: 24rpx;
}

/* 聊天室区域 - 独立区域 */
.chat-section {
  background: white;
  margin: 0 20rpx 10rpx 20rpx;
  border-radius: 20rpx;
  padding: 15rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  min-height: 0;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  margin-bottom: 20rpx;
  min-height: 0;
  overflow-y: auto;
  height: 0;
}

.message-item {
  margin-bottom: 15rpx;
  padding: 10rpx 15rpx;
  border-radius: 10rpx;
}

.message-item.chat {
  background: #f8f9fa;
}

.message-item.system {
  background: #e8f2ff;
  text-align: center;
}

.message-item.correct {
  background: #d4edda;
  text-align: center;
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.message-sender {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
}

.message-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

.system-message {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.correct-message {
  font-size: 26rpx;
  color: #28a745;
  font-weight: 600;
}

.chat-input-section {
  display: flex;
  gap: 15rpx;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.chat-input {
  flex: 1;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 25rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.chat-input:focus {
  border-color: #667eea;
  background: white;
}

.send-btn {
  padding: 15rpx 25rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.send-btn:disabled {
  background: #ccc;
}

.drawer-hint {
  text-align: center;
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 10rpx;
  border: 1rpx solid #ffeaa7;
}

.drawer-hint text {
  font-size: 24rpx;
  color: #856404;
}

/* 游戏结束弹窗 */
.game-over-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.final-scores {
  margin-bottom: 40rpx;
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.score-item:last-child {
  border-bottom: none;
}

.rank {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  min-width: 80rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx;
  background: #f8f9fa;
  color: #666;
  border: 1rpx solid #e0e0e0;
  border-radius: 15rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  flex: 1;
  padding: 20rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 15rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

/* 响应式适配 */
@media (max-width: 400px) {
  .canvas-section {
    min-height: 250rpx;
  }
}

/* 准备状态 */
.waiting-room {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.input-area {
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #f0f0f0;
}

.owner-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.waiting-icon {
  color: #ccc;
  font-size: 24rpx;
}

.ready-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #667eea;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
}

.ready-btn[disabled] {
  background-color: #a0aec0;
  color: #e2e8f0;
}

/* 画手出题阶段 */
.word-input-section {
  background: white;
  margin: 15rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.word-input-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.word-input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.word-input-row {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.word-input {
  flex: 1;
  padding: 20rpx 25rpx;
  border: 2rpx solid #667eea;
  border-radius: 15rpx;
  font-size: 30rpx;
  background: #f8f9ff;
}

.submit-word-btn {
  padding: 20rpx 35rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 15rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.submit-word-btn:disabled {
  background: #ccc;
}

/* 等待出题阶段（猜手视角） */
.waiting-word-section {
  background: white;
  margin: 15rpx;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.waiting-text {
  font-size: 30rpx;
  color: #666;
}

/* 画手词条提示 */
.drawer-word-hint {
  background: #fff3cd;
  border: 1rpx solid #ffeaa7;
  border-radius: 10rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.drawer-word-label {
  font-size: 26rpx;
  color: #856404;
}

.drawer-word-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #856404;
}

/* 猜手提示 */
.guesser-hint {
  background: #e8f4fd;
  border-radius: 10rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 10rpx;
  text-align: center;
}

.guesser-hint text {
  font-size: 26rpx;
  color: #0c5460;
}

/* ===== 画布占位 ===== */
.canvas-placeholder {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.placeholder-text {
  font-size: 30rpx;
  color: #bbb;
}

/* ===== 头像 + 徽章 ===== */
.avatar-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}
.avatar-wrap .player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: block;
  margin-bottom: 0;
}
.avatar-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}
.badge-check {
  color: #28a745;
  font-size: 22rpx;
  font-weight: bold;
}

/* ===== 底部操作区 ===== */
.bottom-section {
  background: white;
  margin: 0 20rpx 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.action-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.action-tip-center {
  text-align: center;
  padding: 10rpx 0;
}
.action-tip-center text {
  font-size: 28rpx;
  color: #666;
}

/* 通用操作按钮 */
.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  text-align: center;
}
.btn-ready {
  background: #667eea;
  color: white;
}
.btn-ready-done {
  background: #a0aec0;
  color: #e2e8f0;
}
.btn-start {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}
.btn-start-disabled {
  background: #e0e0e0;
  color: #aaa;
}
.btn-submit-word {
  width: auto;
  padding: 0 40rpx;
  background: #667eea;
  color: white;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.btn-submit-word[disabled] {
  background: #ccc;
}
.btn-send {
  width: auto;
  padding: 0 36rpx;
  background: #667eea;
  color: white;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.btn-send[disabled] {
  background: #ccc;
}

/* word-input 在底部区域复用 */
.bottom-section .word-input-row {
  display: flex;
  gap: 15rpx;
  align-items: center;
}
.bottom-section .word-input {
  flex: 1;
  padding: 18rpx 22rpx;
  border: 2rpx solid #667eea;
  border-radius: 44rpx;
  font-size: 28rpx;
  background: #f8f9ff;
}

/* ===== 出词弹窗 ===== */
.word-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 950;
}

.word-modal {
  width: 88%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

.word-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.word-modal-tip {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #888;
  text-align: center;
}

.word-modal-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.word-modal-input {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  border: 2rpx solid #667eea;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f8f9ff;
}

.word-modal-btn {
  min-width: 150rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  border: none;
  background: #667eea;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 24rpx;
}

.word-modal-btn[disabled] {
  background: #ccc;
  color: #f1f1f1;
}
