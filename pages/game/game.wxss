/* 游戏容器 */
.game-container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.1), transparent 26%),
    radial-gradient(circle at top right, rgba(255, 215, 255, 0.14), transparent 30%),
    linear-gradient(180deg, #7566d9 0%, #6658c8 38%, #5749b4 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 游戏头部 */
.game-header {
  margin: 18rpx 20rpx 10rpx;
  padding: 16rpx 22rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(37, 18, 93, 0.22);
}

.game-info {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.room-id {
  font-size: 24rpx;
  color: #f8f6ff;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  letter-spacing: 1rpx;
}

.current-word {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
  background: #e8f2ff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.timer {
  min-width: 108rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #432980;
  font-weight: 700;
  background: linear-gradient(135deg, #ffe29f 0%, #ffc76d 100%);
  border-radius: 999rpx;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(255, 185, 93, 0.28);
}

.game-status {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: flex-end;
  min-width: 132rpx;
}

.round-info {
  font-size: 26rpx;
  color: #e8e2ff;
  letter-spacing: 1rpx;
  font-weight: 600;
  text-align: right;
}

/* 画板区域 */
.canvas-section {
  flex-shrink: 0;
  background: #ffffff;
  margin: 10rpx 20rpx 10rpx 20rpx;
  border-radius: 28rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 22rpx 56rpx rgba(53, 31, 121, 0.18);
  height: 37vh;
  overflow: hidden;
}

.canvas-meta {
  flex-shrink: 0;
  min-height: 86rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-bottom: 12rpx;
}

.canvas-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 72rpx;
  gap: 16rpx;
}

.canvas-header-drawer {
  flex-wrap: nowrap;
}

.canvas-tools {
  display: flex;
  gap: 10rpx;
  align-items: center;
  background: #f4f0ff;
  border-radius: 999rpx;
  padding: 6rpx;
  box-shadow: inset 0 0 0 1rpx rgba(103, 84, 196, 0.08);
  flex-shrink: 0;
}

.tool-btn {
  min-width: 74rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: none;
  background: rgba(255, 255, 255, 0.72);
  color: #6c56c7;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  padding: 0 14rpx;
}

.tool-btn.active {
  background: linear-gradient(135deg, #7566d9 0%, #5b4dc0 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(91, 77, 192, 0.24);
}

.clear-btn {
  min-width: 92rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  background: #ef6b7a;
  color: white;
  border: none;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 18rpx rgba(239, 107, 122, 0.18);
}

.canvas-stage {
  flex: 1;
  min-height: 0;
}

.drawing-canvas {
  display: block;
  width: 100%;
  height: 100%;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(252, 250, 255, 1));
  border: 3rpx solid #e5dcff;
  border-radius: 24rpx;
  box-shadow: inset 0 0 0 8rpx rgba(122, 103, 217, 0.05);
}

/* 用户头像区域 */
.players-section {
  background: transparent;
  margin: 0 20rpx 10rpx 20rpx;
  border-radius: 0;
  padding: 6rpx 0 2rpx;
  box-shadow: none;
  flex-shrink: 0;
}

.players-list {
  white-space: nowrap;
  display: flex;
}

.player-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
  padding: 16rpx 14rpx 12rpx;
  border-radius: 18rpx;
  min-width: 120rpx;
  position: relative;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10rpx);
}

.player-item:last-child {
  margin-right: 0;
}

.player-item.is-drawer {
  background: rgba(255, 233, 171, 0.2);
  border: 2rpx solid rgba(255, 221, 126, 0.9);
  box-shadow: 0 12rpx 22rpx rgba(57, 34, 134, 0.2);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  margin-bottom: 10rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.75);
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.player-name {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  text-align: center;
}

.player-score {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.82);
  text-align: center;
}

.player-status {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  display: flex;
  align-items: center;
}

.status-icon {
  font-size: 24rpx;
}

/* 聊天室区域 - 独立区域 */
.chat-section {
  background: #ffffff;
  margin: 0 20rpx 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 18rpx 18rpx 16rpx;
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  box-shadow: 0 18rpx 40rpx rgba(53, 31, 121, 0.18);
  min-height: 30vh;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  height: 0;
  padding-bottom: 12rpx;
}

.chat-empty-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 12rpx;
}

.chat-empty-title {
  font-size: 30rpx;
  color: #6e60b4;
  font-weight: 700;
}

.chat-empty-desc {
  font-size: 24rpx;
  color: #9a90c1;
}

.message-item {
  margin-bottom: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
}

.message-item.chat {
  background: #f7f5ff;
  border: 1rpx solid rgba(103, 84, 196, 0.08);
}

.message-item.system {
  background: #e8f2ff;
  text-align: center;
}

.message-item.correct {
  background: linear-gradient(135deg, #e6fff1 0%, #f0fff6 100%);
  text-align: center;
  border: 1rpx solid rgba(55, 148, 92, 0.18);
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.message-sender {
  font-size: 22rpx;
  color: #6b59c9;
  font-weight: 600;
}

.message-text {
  font-size: 26rpx;
  color: #3f355f;
  line-height: 1.4;
}

.system-message {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.correct-message {
  font-size: 26rpx;
  color: #23844f;
  font-weight: 700;
}

.chat-input-section {
  display: flex;
  gap: 15rpx;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid rgba(103, 84, 196, 0.1);
}

.chat-guess-input {
  flex: 1;
  height: 72rpx;
  padding: 0 26rpx;
  border: 1rpx solid #e0d7ff;
  border-radius: 36rpx;
  background: #f8f6ff;
  font-size: 28rpx;
  color: #3b315a;
}

.chat-guess-input:focus {
  border-color: #7566d9;
  background: #ffffff;
}

.chat-guess-input.is-disabled {
  color: #9aa3af;
  background: #f1f3f6;
  border-color: #e5e7eb;
}

.chat-send-btn {
  width: auto;
  min-width: 112rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 20rpx rgba(90, 75, 192, 0.22);
}

.chat-send-btn[disabled] {
  background: #ccc;
  color: white;
}

.chat-send-btn.is-disabled {
  background: #d5d9e0;
  color: #f8f9fb;
}

.chat-input {
  flex: 1;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 25rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.chat-input:focus {
  border-color: #667eea;
  background: white;
}

.send-btn {
  padding: 15rpx 25rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.send-btn:disabled {
  background: #ccc;
}

.drawer-hint {
  text-align: center;
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 10rpx;
  border: 1rpx solid #ffeaa7;
}

.drawer-hint text {
  font-size: 24rpx;
  color: #856404;
}

/* 游戏结束弹窗 */
.game-over-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(6, 16, 22, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 100%;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.28);
}

.result-hero {
  margin-bottom: 26rpx;
}

.result-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4f0ff;
  color: #6b59c9;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #43356f;
  text-align: center;
  margin-bottom: 22rpx;
}

.winner-card {
  padding: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff8eb 0%, #fff2c8 100%);
  border: 1rpx solid rgba(240, 196, 95, 0.38);
  text-align: center;
  box-shadow: 0 18rpx 34rpx rgba(217, 177, 78, 0.16);
}

.winner-crown {
  display: block;
  font-size: 54rpx;
  margin-bottom: 8rpx;
}

.winner-rank {
  display: block;
  font-size: 24rpx;
  color: #9f6c17;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.winner-name {
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  color: #5d4320;
  font-weight: 700;
}

.winner-score {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #8d6320;
  font-weight: 600;
}

.final-scores {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #faf8ff;
  border: 1rpx solid #eee8ff;
}

.score-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rank-badge {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ece7ff 0%, #e1d8ff 100%);
  flex-shrink: 0;
}

.rank-0 {
  background: linear-gradient(135deg, #ffe7a5 0%, #ffd56a 100%);
}

.rank-1 {
  background: linear-gradient(135deg, #eef1f7 0%, #dbe1ee 100%);
}

.rank-2 {
  background: linear-gradient(135deg, #f2ddd2 0%, #e4b494 100%);
}

.rank {
  font-size: 28rpx;
  color: #574793;
  font-weight: 600;
}

.score-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.score-name {
  font-size: 30rpx;
  color: #43356f;
  font-weight: 700;
}

.score-rank-text {
  font-size: 22rpx;
  color: #9a90c1;
}

.score-points {
  font-size: 30rpx;
  color: #6b59c9;
  font-weight: 700;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx;
  background: #f8f6ff;
  color: #675a90;
  border: 1rpx solid #e1dbf7;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  flex: 1;
  padding: 20rpx;
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
  border: none;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

/* 响应式适配 */
@media (max-width: 400px) {
  .canvas-section {
    min-height: 250rpx;
  }
}

/* 准备状态 */
.waiting-room {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.input-area {
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #f0f0f0;
}

.owner-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.waiting-icon {
  color: #ccc;
  font-size: 24rpx;
}

.ready-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #667eea;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
}

.ready-btn[disabled] {
  background-color: #a0aec0;
  color: #e2e8f0;
}

/* 画手出题阶段 */
.word-input-section {
  background: white;
  margin: 15rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.word-input-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.word-input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.word-input-row {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.word-input {
  flex: 1;
  padding: 20rpx 25rpx;
  border: 2rpx solid #667eea;
  border-radius: 15rpx;
  font-size: 30rpx;
  background: #f8f9ff;
}

.submit-word-btn {
  padding: 20rpx 35rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 15rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.submit-word-btn:disabled {
  background: #ccc;
}

/* 等待出题阶段（猜手视角） */
.waiting-word-section {
  background: white;
  margin: 15rpx;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.waiting-text {
  font-size: 30rpx;
  color: #666;
}

/* 画手词条提示 */
.drawer-word-hint {
  background: linear-gradient(135deg, #f5f0ff 0%, #eee7ff 100%);
  border: 1rpx solid rgba(117, 102, 217, 0.18);
  border-radius: 16rpx;
  padding: 12rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 52rpx;
  flex: 1;
  min-width: 0;
}

.drawer-word-label {
  font-size: 24rpx;
  color: #6e5fb0;
  flex-shrink: 0;
}

.drawer-word-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #4c3f80;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 猜手提示 */
.guesser-hint {
  background: linear-gradient(135deg, #f6f2ff 0%, #f0ebff 100%);
  border: 1rpx solid rgba(117, 102, 217, 0.14);
  border-radius: 16rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 12rpx;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.guesser-hint text {
  font-size: 26rpx;
  color: #6558a2;
}

/* ===== 画布占位 ===== */
.canvas-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  padding: 24rpx;
}
.placeholder-text {
  font-size: 30rpx;
  color: #8a80b6;
  text-align: center;
}

.canvas-placeholder-action {
  width: 100%;
  max-width: 460rpx;
}

.canvas-placeholder-note text {
  font-size: 24rpx;
  color: #a095c8;
  text-align: center;
}

/* ===== 头像 + 徽章 ===== */
.avatar-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}
.avatar-wrap .player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: block;
  margin-bottom: 0;
}
.avatar-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}
.badge-check {
  color: #28a745;
  font-size: 22rpx;
  font-weight: bold;
}

/* 通用操作按钮 */
.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  box-shadow: 0 16rpx 30rpx rgba(46, 26, 112, 0.22);
}
.btn-ready {
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
}
.btn-ready-done {
  background: rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.82);
  box-shadow: none;
}
.btn-start {
  background: linear-gradient(135deg, #7d6ff0 0%, #5c4bcf 100%);
  color: white;
}
.btn-start-disabled {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.74);
  box-shadow: none;
}
.btn-submit-word {
  width: auto;
  padding: 0 40rpx;
  background: #667eea;
  color: white;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.btn-submit-word[disabled] {
  background: #ccc;
}
.btn-send {
  width: auto;
  padding: 0 36rpx;
  background: #667eea;
  color: white;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.btn-send[disabled] {
  background: #ccc;
}

/* word-input 在底部区域复用 */
.bottom-section .word-input-row {
  display: flex;
  gap: 15rpx;
  align-items: center;
}
.bottom-section .word-input {
  flex: 1;
  padding: 18rpx 22rpx;
  border: 2rpx solid #667eea;
  border-radius: 44rpx;
  font-size: 28rpx;
  background: #f8f9ff;
}

/* ===== 出词弹窗 ===== */
.word-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 950;
}

.word-modal {
  width: 88%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

.word-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #43356f;
  text-align: center;
}

.word-modal-tip {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #8e88a7;
  text-align: center;
}

.word-modal-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.word-modal-input {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  border: 2rpx solid #e0d7ff;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f8f6ff;
}

.word-modal-btn {
  min-width: 150rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  border: none;
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 24rpx;
}

.word-modal-btn[disabled] {
  background: #ccc;
  color: #f1f1f1;
}
