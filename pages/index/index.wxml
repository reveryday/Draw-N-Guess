<view class="container">

  <!-- 用户信息 -->
  <view class="user-info" wx:if="{{isLoggedIn}}">
    <image class="avatar avatar-large" src="{{avatarUrl}}"></image>
    <text class="username">{{nickname}}</text>
  </view>

  <!-- 登录 -->
  <view class="auth-section" wx:else>
    <button class="btn-primary" open-type="chooseAvatar" bindchooseavatar="getAvatar">
      <image class="avatar avatar-large" src="{{avatarUrl}}"/>
    </button>
    <input class="nickname-input" type="nickname" placeholder="请输入昵称" value="{{nickName}}" maxlength="10" bindblur="getNickName"/>
    <button class="btn-primary btn-login" bindtap="saveUserInfo">登录</button>
  </view>

  <!-- 主要功能区域 -->
  <view class="main-actions" wx:if="{{isLoggedIn}}">
    <view class="action-card" bindtap="intoCreate">
      <view class="action-icon"></view>
      <view class="action-content">
        <text class="action-title">创建房间</text>
        <text class="action-desc">邀请朋友一起玩</text>
      </view>
      <view class="action-arrow">></view>
    </view>

    <view class="action-card" bindtap="joinRoom">
      <view class="action-icon"></view>
      <view class="action-content">
        <text class="action-title">加入房间</text>
        <text class="action-desc">输入房间号加入游戏</text>
      </view>
      <view class="action-arrow">></view>
    </view>
  </view>
</view>

<!-- 加入房间弹窗 -->
<view class="modal" wx:if="{{showJoinModal}}" bindtap="hideJoinModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">加入房间</text>
      <text class="modal-close" bindtap="hideJoinModal">x</text>
    </view>
    <view class="modal-body">
      <view class="input-group">
        <text class="input-label">房间号</text>
        <input class="input-field" placeholder="请输入6位房间号" maxlength="6" type="number" bindinput="onRoomIdInput" value="{{inputRoomId}}"/>
      </view>
      <button class="btn-primary" bindtap="confirmJoinRoom" disabled="{{!inputRoomId || inputRoomId.length !== 6}}">加入房间</button>
    </view>
  </view>
</view>
