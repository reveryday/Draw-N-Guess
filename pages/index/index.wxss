.main-actions {
  margin-bottom: 28rpx;
  width: 100%;
  max-width: 600rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.action-card {
  background: #fffdf8;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  box-shadow: 0 24rpx 60rpx rgba(176, 116, 57, 0.2);
  transition: all 0.3s ease;
}

.action-card:active {
  transform: translateY(2rpx) scale(0.995);
  box-shadow: 0 14rpx 30rpx rgba(176, 116, 57, 0.14);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff8d6b 0%, #ff6f61 100%);
  border-radius: 22rpx;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.action-icon image {
  width: 40rpx;
  height: 40rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4b2e59;
  margin-bottom: 5rpx;
}

.action-desc {
  display: block;
  font-size: 26rpx;
  color: #7a627f;
}

.action-arrow {
  font-size: 32rpx;
  color: #d5a285;
  font-weight: bold;
}

/* 用户信息 */
.auth-section {
  text-align: center;
  margin-bottom: 40rpx;
  width: 100%;
  max-width: 600rpx;
  background: #fffdf8;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 60rpx rgba(176, 116, 57, 0.2);
}

.user-info {
  background: rgba(255, 253, 248, 0.7);
  border-radius: 28rpx;
  padding: 34rpx 42rpx;
  margin-bottom: 40rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow: 0 24rpx 52rpx rgba(176, 116, 57, 0.18);
}

.username {
  display: block;
  color: #4b2e59;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 0rpx 0 0rpx;
  font-size: 32rpx;
  border: 2rpx solid #f2d6bf;
  border-radius: 18rpx;
  background: #fff8ec;
  transition: border-color 0.2s;
  margin: 40rpx auto 0;
  text-align: center;
  color: #4b2e59;
}

.nickname-input:focus {
  border-color: #ff7a59;
  background: #fff;
}

.placeholder {
  color: #bbb;
}

.btn-login {
  margin-top: 32rpx;
  width: 100%;
}

.avatar-picker {
  width: 148rpx;
  height: 148rpx;
  padding: 0;
  border: none;
  background: linear-gradient(135deg, #ff8d6b 0%, #ff6f61 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 32rpx rgba(255, 111, 97, 0.22);
}

.avatar-picker::after {
  border: none;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(8, 4, 28, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fffdf8;
  border-radius: 28rpx;
  width: 88%;
  max-width: 680rpx;
  overflow: hidden;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.28);
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0ebff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4b2e59;
}

.modal-close {
  font-size: 40rpx;
  color: #c78f73;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .input-field {
  width: 100%;
  box-sizing: border-box;
  height: 96rpx;
  line-height: 96rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  text-align: left;
  font-size: 28rpx;
}

.modal-body .btn-primary {
  width: 100%;
  margin-top: 12rpx;
}

/* 加载覆盖层 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

/* .loading样式已在app.wxss中定义 */

/* 响应式适配 */
@media (max-width: 400px) {
  .container {
    padding: 30rpx 20rpx;
  }
  
  .action-card {
    padding: 25rpx;
  }
  
  .action-icon {
    width: 70rpx;
    height: 70rpx;
    margin-right: 25rpx;
  }
  
  .action-title {
    font-size: 30rpx;
  }
  
  .action-desc {
    font-size: 24rpx;
  }
}
