.main-actions {
  margin-bottom: 40rpx;
  width: 100%;
  max-width: 600rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.action-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.action-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 15rpx;
}

.action-icon image {
  width: 40rpx;
  height: 40rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 5rpx;
}

.action-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.action-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: bold;
}

/* 用户信息 */
.auth-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.user-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.username {
  display: block;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 0rpx 0 0rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
  transition: border-color 0.2s;
  margin: 40rpx auto 0;
  text-align: center;
}

.nickname-input:focus {
  border-color: #07c160;
  background: #fff;
}

.placeholder {
  color: #bbb;
}

.btn-login {
  margin-top: 40rpx;   /* 可根据视觉微调 40~80rpx */
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  width: 85%;
  max-width: 90%;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

/* 加载覆盖层 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

/* .loading样式已在app.wxss中定义 */

/* 响应式适配 */
@media (max-width: 400px) {
  .container {
    padding: 30rpx 20rpx;
  }
  
  .action-card {
    padding: 25rpx;
  }
  
  .action-icon {
    width: 70rpx;
    height: 70rpx;
    margin-right: 25rpx;
  }
  
  .action-title {
    font-size: 30rpx;
  }
  
  .action-desc {
    font-size: 24rpx;
  }
}