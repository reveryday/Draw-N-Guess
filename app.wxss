.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.1), transparent 26%),
    radial-gradient(circle at top right, rgba(255, 215, 255, 0.14), transparent 30%),
    linear-gradient(180deg, #7566d9 0%, #6658c8 38%, #5749b4 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* 通用样式 */
.btn-primary {
  background: linear-gradient(135deg, #7566d9 0%, #5a4bc0 100%);
  color: white;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(90, 75, 192, 0.22);
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 18rpx rgba(90, 75, 192, 0.2);
}

.btn-secondary {
  background: #f8f6ff;
  color: #675a90;
  border: 1rpx solid #e1dbf7;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary:active {
  background: #f8f9fa;
}

.card {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx;
  margin: 15rpx;
  box-shadow: 0 22rpx 56rpx rgba(53, 31, 121, 0.18);
  width: 100%;
  box-sizing: border-box;
}

.input-group {
  margin: 30rpx 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #53457f;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.input-field {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0d7ff;
  border-radius: 18rpx;
  font-size: 30rpx;
  background: #f8f6ff;
  color: #3b315a;
}

.input-field:focus {
  border-color: #7566d9;
  background: white;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.text-primary {
  color: #6b59c9;
}

.text-secondary {
  color: #666;
}

.text-success {
  color: #28a745;
}

.text-danger {
  color: #dc3545;
}

.text-warning {
  color: #ffc107;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-40 {
  margin-bottom: 40rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-40 {
  margin-top: 40rpx;
}

.p-20 {
  padding: 20rpx;
}

.p-40 {
  padding: 40rpx;
}

/* 头像样式 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.75);
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
}

/* 状态指示器 */
.status-indicator {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 10rpx;
}

.status-online {
  background: #28a745;
}

.status-offline {
  background: #dc3545;
}

.status-drawing {
  background: #ffc107;
}

.status-guessing {
  background: #17a2b8;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

.pulse {
  animation: pulse 1s infinite;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #7566d9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 消息提示 */
.message {
  padding: 20rpx 30rpx;
  border-radius: 18rpx;
  margin: 20rpx 0;
  font-size: 28rpx;
}

.message-success {
  background: #d4edda;
  color: #155724;
  border: 1rpx solid #c3e6cb;
}

.message-error {
  background: #f8d7da;
  color: #721c24;
  border: 1rpx solid #f5c6cb;
}

.message-warning {
  background: #f5f0ff;
  color: #6e5fb0;
  border: 1rpx solid rgba(117, 102, 217, 0.18);
}

.message-info {
  background: #f6f2ff;
  color: #6558a2;
  border: 1rpx solid rgba(117, 102, 217, 0.14);
}
